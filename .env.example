# Environment Configuration

# API Configuration
VITE_API_URL=http://localhost:3001/api

# Backend Server
BACKEND_PORT=3001
NODE_ENV=development

# PWA Configuration
VITE_PWA_ENABLED=true

# Feature Flags
ENABLE_NOTIFICATIONS=true
ENABLE_SHARING=true
ENABLE_ANALYTICS=true
ENABLE_OFFLINE_MODE=true

# Notification Settings
NOTIFICATION_CHECK_INTERVAL=30000  # 30 seconds

# File Upload Configuration
MAX_FILE_SIZE=52428800  # 50MB in bytes
ALLOWED_FILE_TYPES=pdf,docx,xlsx,pptx,jpeg,jpg,png,txt

# Database Configuration (if using MongoDB/PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=agriarchive
DB_USER=admin
DB_PASSWORD=

# JWT Configuration (for future auth)
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRY=7d

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=

# Analytics
ENABLE_ANALYTICS=true
ANALYTICS_ENDPOINT=https://analytics.example.com
